# Open Computer Use - Environment Variables
# Copy this file to .env and customize

# === LLM Provider (required) ===
# Works with any OpenAI-compatible API: OpenAI, OpenRouter, LiteLLM, etc.
OPENAI_API_KEY=sk-...
# OPENAI_API_BASE_URL=https://openrouter.ai/api/v1

# === Computer Use Server ===
# MCP API key for endpoint authorization (leave empty for development)
MCP_API_KEY=
# Docker image used for sandbox containers
DOCKER_IMAGE=open-computer-use:latest
# Timeouts
COMMAND_TIMEOUT=120
SUB_AGENT_TIMEOUT=3600
# Single-user mode:
#   not set  = lenient (default container + warning if no X-Chat-Id)
#   true     = always use one container, no chat ID needed
#   false    = strict multi-user, X-Chat-Id required
# SINGLE_USER_MODE=true

# Public URL where the sandbox file/preview server is reachable from the user's
# browser. This MUST match the `FILE_SERVER_URL` Valve configured in the Open
# WebUI filter (Admin → Functions → computer_link_filter → Valves). If the two
# disagree, the filter silently skips appending the preview iframe/buttons and
# the preview panel will never appear — with no error in the logs.
# Leave commented to keep the default (http://computer-use-server:8081). The
# default is only valid when Open WebUI is on the same Docker network AND the
# browser can reach that hostname (i.e. not generally true for anything except
# local dev with both stacks on the same host). See
# docs/openwebui-filter.md#two-file_server_url-settings--they-must-match
# FILE_SERVER_URL=http://localhost:8081

# === PostgreSQL ===
POSTGRES_PASSWORD=openwebui

# === Open WebUI ===
OPENWEBUI_VERSION=0.8.12
OPENWEBUI_PORT=3000
MCP_PORT=8081

# === Optional: Large tool result truncation ===
# Prevents context window exhaustion from large MCP tool outputs (Metabase, Playwright, etc.)
# Requires fix_large_tool_results patch enabled in openwebui/Dockerfile
# TOOL_RESULT_MAX_CHARS=50000
# TOOL_RESULT_PREVIEW_CHARS=2000

# === Optional: External skill provider ===
# URL of an external service that returns per-user skill configuration for
# the /system-prompt endpoint. When empty (default), the orchestrator falls
# back to DEFAULT_PUBLIC_SKILLS — the stock community skill set — without
# contacting any external service. Wire this only if you run your own
# skill/settings provider (out of scope for the community image).
# MCP_TOKENS_URL=
# MCP_TOKENS_API_KEY=

# === Optional: Vision API (for describe-image skill) ===
# VISION_API_KEY=
# VISION_API_URL=https://api.openai.com/v1
# VISION_MODEL=gpt-4o

# === Optional: Claude Code sub-agent ===
# ANTHROPIC_AUTH_TOKEN=
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# === Optional: Claude Code sub-agent gateway overrides ===
# Pass-through to sandbox when set. Leave commented to use Claude Code defaults.
# ANTHROPIC_MODEL=
# ANTHROPIC_DEFAULT_SONNET_MODEL=
# ANTHROPIC_DEFAULT_OPUS_MODEL=
# ANTHROPIC_DEFAULT_HAIKU_MODEL=
# CLAUDE_CODE_SUBAGENT_MODEL=
# CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS=
# DISABLE_PROMPT_CACHING=
# DISABLE_PROMPT_CACHING_SONNET=
# DISABLE_PROMPT_CACHING_OPUS=
# DISABLE_PROMPT_CACHING_HAIKU=

# === Optional: GitLab integration ===
# GITLAB_HOST=gitlab.com
# GITLAB_TOKEN=
